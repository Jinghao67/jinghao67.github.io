---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
void noMarginTop;

const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
---

<footer class:list={["mt-auto", className]} {...attrs}>
  <div
    class="bg-foreground text-background mt-16 flex min-h-9 flex-col items-center justify-center gap-1 px-4 py-3 text-center text-xs sm:flex-row"
  >
    <span>{t.footer.copyright} &#169; {currentYear} Jinghao.</span>
    <span class="hidden sm:inline">Hosted by GitHub Pages.</span>
    <Socials />
  </div>
</footer>
