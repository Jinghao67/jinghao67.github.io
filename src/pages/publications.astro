---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { publications } from "@/data/publications";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const sortedPublications = [...publications].sort((a, b) => b.year - a.year);
---

<Layout
  title={`${t.pages.publicationsTitle} | ${config.site.title}`}
  description={t.pages.publicationsDesc}
>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle={t.pages.publicationsTitle}
    pageDesc={t.pages.publicationsDesc}
  >
    <ol class="space-y-8">
      {
        sortedPublications.map((publication, index) => (
          <li class="grid gap-4 sm:grid-cols-[9rem_1fr]">
            <div class="text-muted-foreground text-sm sm:text-right">
              {publication.image && (
                <img
                  src={publication.image}
                  alt=""
                  class="border-border mb-2 aspect-[4/3] w-full rounded border object-cover"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              )}
              <span>{publication.year}</span>
            </div>
            <article>
              <h2 class="text-xl font-semibold">
                <span class="text-accent">{publication.title}</span>
              </h2>
              <p class="mt-1">{publication.authors}</p>
              <p class="text-muted-foreground mt-1 italic">
                {publication.venue}
              </p>
              {publication.summary && <p class="mt-2">{publication.summary}</p>}
              {publication.links && publication.links.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {publication.links.map(link => (
                    <a
                      href={link.href}
                      class="border-border hover:border-accent hover:text-accent rounded border px-2 py-1 text-sm"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </Main>

  <Footer />
</Layout>
