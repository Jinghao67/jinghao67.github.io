---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import { publications } from "@/data/publications";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = getSortedPosts(await getCollection("posts")).slice(0, 3);
const selectedPublications = publications
  .filter(publication => publication.selected)
  .slice(0, 4);

const dateFormatter = new Intl.DateTimeFormat(locale, {
  year: "numeric",
  month: "short",
  day: "2-digit",
});
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index" class="app-layout pt-12">
    <section class="grid gap-8 md:grid-cols-[1fr_17rem] md:items-start">
      <div class="space-y-5 text-base leading-7">
        <h1 class="text-4xl font-light sm:text-5xl">
          <span class="font-bold">Jinghao Zhang</span>
        </h1>

        <p>
          Hi, I am <strong>Jinghao Zhang</strong>, an undergraduate student at
          <span class="text-accent">Shandong University</span>. I am conducting
          research at the <span class="text-accent"
            >General Artificial Intelligence Lab (GAI Lab)</span
          >, advised by <strong>Prof. Keji He</strong>. My research interests
          include <strong>theoretical world models</strong>, especially how
          models can fundamentally develop the capacity for world modeling, and
          <strong>representation learning</strong>.
        </p>

        <p>
          Previously, I worked as a <strong>Research Assistant (RA)</strong> at the
          <span class="text-accent"
            >Trustworthy and General Artificial Intelligence Laboratory (TGAI
            Lab)</span
          >, <span class="text-accent">Westlake University</span>, under the
          supervision of <strong>Prof. Yaochu Jin</strong>, where I studied
          <strong>brain-inspired Embodied AI</strong>.
        </p>

        <p>
          Below are my <strong>research experiences</strong> and
          <strong>publications</strong>. If you would like to know me better,
          you may enjoy reading my
          <a
            href={getRelativeLocaleUrl(locale, "about")}
            class="text-accent hover:underline"
          >
            research stories
          </a>
          and
          <a
            href={getRelativeLocaleUrl(locale, "blog")}
            class="text-accent hover:underline"
          >
            blog posts
          </a>.
          <a
            href="/uploads/Jinghao_Zhang_CV.pdf"
            class="text-accent hover:underline"
          >
            Get my CV here.
          </a>
        </p>
      </div>

      <aside class="md:sticky md:top-24">
        <img
          src="/uploads/profile.jpg"
          alt="Jinghao in the snow"
          class="border-border mx-auto aspect-square w-full max-w-72 rounded border object-cover md:max-w-none"
          loading="eager"
        />
        <div class="mt-4 font-mono text-sm leading-6">
          <p>Jinghao</p>
          <p>
            <a
              href="mailto:zjhlucky1570@163.com"
              class="hover:text-accent break-all"
            >
              zjhlucky1570@163.com
            </a>
          </p>
          <p>
            <a
              href="mailto:zhangjh6767@gmail.com"
              class="hover:text-accent break-all"
            >
              zhangjh6767@gmail.com
            </a>
          </p>
          <p>
            GitHub / Scholar /
            <a
              href="/uploads/Jinghao_Zhang_CV.pdf"
              class="text-accent hover:underline">CV</a
            >
          </p>
        </div>
      </aside>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-3xl font-light">
        <a
          href={getRelativeLocaleUrl(locale, "blog")}
          class="hover:text-accent"
        >
          latest posts
        </a>
      </h2>

      {
        posts.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="w-full border-separate border-spacing-y-2 text-left">
              <tbody>
                {posts.map(post => (
                  <tr>
                    <th class="text-muted-foreground w-36 pe-4 align-top text-sm font-normal whitespace-nowrap">
                      <time datetime={post.data.pubDatetime.toISOString()}>
                        {dateFormatter.format(post.data.pubDatetime)}
                      </time>
                    </th>
                    <td>
                      <a
                        href={getPostUrl(post.id, post.filePath, locale)}
                        class="text-accent hover:underline"
                      >
                        {post.data.title}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="text-muted-foreground">No posts yet.</p>
        )
      }
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-3xl font-light">
        <a
          href={getRelativeLocaleUrl(locale, "publications")}
          class="hover:text-accent"
        >
          selected publications
        </a>
      </h2>

      <ol class="space-y-7">
        {
          selectedPublications.map(publication => (
            <li class="grid gap-4 sm:grid-cols-[8rem_1fr]">
              {publication.image && (
                <img
                  src={publication.image}
                  alt=""
                  class="border-border aspect-[4/3] w-full rounded border object-cover"
                  loading="lazy"
                />
              )}
              <article>
                <h3 class="text-accent text-lg font-semibold">
                  {publication.title}
                </h3>
                <p class="mt-1">{publication.authors}</p>
                <p class="text-muted-foreground mt-1 italic">
                  {publication.venue}, {publication.year}
                </p>
                {publication.summary && (
                  <p class="mt-2 text-sm leading-6">{publication.summary}</p>
                )}
                {publication.links && publication.links.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-2">
                    {publication.links.map(link => (
                      <a
                        href={link.href}
                        class="border-border hover:border-accent hover:text-accent rounded border px-2 py-1 text-xs"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </article>
            </li>
          ))
        }
      </ol>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem(
      "backUrl",
      import.meta.env.BASE_URL.replace(/\/?$/, "/")
    );
  });
</script>
